# Claude API key for edit script generation (Step 3)
ANTHROPIC_API_KEY=sk-ant-...

# Optional OpenAI key for TTS narration generation
OPENAI_API_KEY=sk-...

# Optional TTS stage configuration. Leave TTS_PROVIDER empty to disable.
TTS_PROVIDER=
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_AUDIO_FORMAT=wav
TTS_INSTRUCTIONS=
