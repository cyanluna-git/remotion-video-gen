# Claude API key for edit script generation (Step 3)
ANTHROPIC_API_KEY=sk-ant-...

# Optional OpenAI key for TTS narration generation
OPENAI_API_KEY=sk-...

# Optional vision QA configuration. Leave VISION_QA_PROVIDER empty to disable.
VISION_QA_PROVIDER=
VISION_QA_MODEL=gpt-4.1-mini
VISION_QA_DETAIL=low

# Optional TTS stage configuration. Leave TTS_PROVIDER empty to disable.
CLIP_RANKING_PROVIDER=heuristic
TTS_PROVIDER=
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_AUDIO_FORMAT=wav
TTS_INSTRUCTIONS=
